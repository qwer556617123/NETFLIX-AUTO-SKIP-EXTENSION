{
  "manifest_version": 3,
  "name": "Netflix Auto Skip",
  "version": "1.0.0",
  "description": "自動跳過 Netflix 片頭、前情提要、片尾，並自動播放下一集。",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["*://*.netflix.com/watch/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
